# ============================================================
# .env.example
# このファイルを .env にコピーして実際の値を設定してください。
# .env は .gitignore で除外されているため、GitHubには公開されません。
# ============================================================

# WordPress サイトのURL（末尾スラッシュなし）
WORDPRESS_SITE_URL=https://your-wordpress-site.com

# APIキー（WordPressプラグインとChatGPT両方で同じ値を使用）
# 推奨: 32文字以上のランダムな英数字記号
LTS_API_KEY=your-secret-api-key-here

# ============================================================
# WordPress側の設定（wp-config.php に追記）
# ============================================================
# define('LTS_API_KEY', 'your-secret-api-key-here');

# ============================================================
# ChatGPT Custom GPT側の設定
# ============================================================
# Actions > Authentication > API Key
#   Auth Type: API Key
#   API Key: your-secret-api-key-here
#   Auth Type: Custom
#   Custom Header Name: X-API-Key
